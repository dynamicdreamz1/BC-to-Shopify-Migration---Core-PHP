,"alt":"226_main_image_4","position":5,"product_id":10201319604538,"created_at":"2026-02-18T01:54:27-05:00","updated_at":"2026-02-18T01:54:27-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112721113402","width":4288,"height":2088,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4003E_Inputs__23001.jpg?v=1771397667","variant_ids":[]},{"id":55073533329722,"alt":"226_main_image_5","position":6,"product_id":10201319604538,"created_at":"2026-02-18T01:54:27-05:00","updated_at":"2026-02-18T01:54:27-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112721146170","width":1280,"height":853,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4003E_EthernetSerial__23094.jpg?v=1771397667","variant_ids":[]}],"image":{"id":55073533165882,"alt":"226_main_image_0","position":1,"product_id":10201319604538,"created_at":"2026-02-18T01:54:27-05:00","updated_at":"2026-02-18T01:54:27-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112720982330","width":4373,"height":4373,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4003E_3__73168.jpg?v=1771397667","variant_ids":[]}}}
