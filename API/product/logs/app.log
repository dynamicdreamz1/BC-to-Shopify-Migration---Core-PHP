eight":948,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4863E_Side__46854.jpg?v=1771397849","variant_ids":[]},{"id":55073549484346,"alt":"-","position":6,"product_id":10201321472314,"created_at":"2026-02-18T01:57:29-05:00","updated_at":"2026-02-18T01:57:29-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112737136954","width":386,"height":200,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4863E_Left__09756.1709130483.386.513.jpg?v=1771397849","variant_ids":[]}],"image":{"id":55073549320506,"alt":"258_main_image_0","position":1,"product_id":10201321472314,"created_at":"2026-02-18T01:57:29-05:00","updated_at":"2026-02-18T01:57:29-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112736973114","width":1000,"height":519,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_IMS-4863E_Left__09756.jpg?v=1771397849","variant_ids":[]}}}
