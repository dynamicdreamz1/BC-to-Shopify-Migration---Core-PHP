[2026-02-18 07:40:19] [INFO] Product variant images has been updated - Shopidy ID - 10201311772986 - BC id=117 => {"product":{"id":10201311772986,"title":"2.8K Type Weatherproof Temperature Sensor","body_html":"\u003Ch3\u003EWeatherproof temperature monitoring\u003C\/h3\u003E\n\u003Cul\u003E\n\u003Cli style=\"font-weight: 400;\"\u003EMeasures temperature from -20\u00b0 to 176\u00b0F | -28\u00b0 to 80\u00b0C\u003C\/li\u003E\n\u003Cli style=\"font-weight: 400;\"\u003EAccurate to \u00b1 1\u00b0F |\u00a0 \u00b1 .56\u00b0C\u003C\/li\u003E\n\u003Cli style=\"font-weight: 400;\"\u003EIncludes 12\u2019 of wire and mounting clip\u003C\/li\u003E\n\u003Cli style=\"font-weight: 400;\"\u003ESuitable for use in wet or dirty environments\u003C\/li\u003E\n\u003C\/ul\u003E\u003Cp style=\"font-weight: 400;\"\u003EThe Weatherproof Temperature Sensor can be used with all Sensaphone models to measure the temperature in a wet or dirty environment. The Sensaphone will trigger an alarm when the temperature falls outside of the programmed high or low temperature limit. The sensor can be anchored in place using the included mounting clip. The sensor is ideal for cold storage applications such as refrigerators or freezers, agricultural applications such as greenhouses or anywhere a temperature measurement is required away from the Sensaphone. The included 12 feet of wire can be extended up to 1,000\u2019 with optional accessory wire.\u003C\/p\u003E\n\u003Cp style=\"font-weight: 400;\"\u003EAn optional NIST traceable certificate is available.\u003C\/p\u003E\n\u003Cp style=\"font-weight: 400;\"\u003E\u003C!-- pagebreak --\u003E\u003C\/p\u003E\n\u003Ch3\u003ETechnical Specifications\u003C\/h3\u003E\n\u003Cp style=\"font-weight: 400;\"\u003E\u003Cstrong\u003ESensor Temperature Range:\u003C\/strong\u003E -20\u00b0 to 176\u00b0F | -28\u00b0 to 80\u00b0C\u003Cbr\u003E\u003Cstrong\u003EAccuracy:\u003C\/strong\u003E 1\u00b0F | .56\u00b0C\u003Cbr\u003E\u003Cstrong\u003EConnection:\u003C\/strong\u003E Hardwired\u003Cbr\u003E\u003Cstrong\u003EDimensions:\u003C\/strong\u003E 12' of wire | 3.5m\u003Cbr\u003E\u003Cstrong\u003ESensor Series:\u003C\/strong\u003E 2.8K Series\u003Cbr\u003E\u003Cstrong\u003ENotes:\u003C\/strong\u003E Available with NIST Certification\u003C\/p\u003E\n\u003Ch3\u003EDownloads\u003C\/h3\u003E\n\u003Cp\u003E\u003Ca href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/FGD-0101_CS.pdf\"\u003E2.8K Type Weatherproof Temperature Sensor Sales Brochure\u003C\/a\u003E\u003Cbr\u003E\u003Ca href=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/LIT-0055%202.8K%20instructions.pdf\"\u003E2.8K Type Weatherproof Temperature Sensor Instructions\u003C\/a\u003E\u003C\/p\u003E","vendor":"Sensaphone","product_type":"physical","created_at":"2026-02-18T01:40:18-05:00","handle":"28k-type-weatherproof-temperature-sensor","updated_at":"2026-02-18T01:40:18-05:00","published_at":"2026-02-18T01:40:16-05:00","template_suffix":null,"published_scope":"global","tags":"BRAND__Sensaphone, CAT__Temperature Sensors__VAL, OLD__117__ID, TYPE__physical","status":"active","admin_graphql_api_id":"gid:\/\/shopify\/Product\/10201311772986","variants":[{"id":53038643872058,"product_id":10201311772986,"title":"NIST Certification","price":"130.00","position":1,"inventory_policy":"continue","compare_at_price":null,"option1":"NIST Certification","option2":null,"option3":null,"created_at":"2026-02-18T01:40:18-05:00","updated_at":"2026-02-18T01:40:18-05:00","taxable":true,"barcode":"","fulfillment_service":"manual","grams":454,"inventory_management":"shopify","requires_shipping":true,"sku":"FGD-0101-NIST","weight":1,"weight_unit":"lb","inventory_item_id":55065748078906,"inventory_quantity":0,"old_inventory_quantity":0,"admin_graphql_api_id":"gid:\/\/shopify\/ProductVariant\/53038643872058","image_id":null},{"id":53038643904826,"product_id":10201311772986,"title":"None","price":"30.00","position":2,"inventory_policy":"continue","compare_at_price":null,"option