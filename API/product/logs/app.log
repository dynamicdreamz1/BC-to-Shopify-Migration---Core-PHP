]},{"id":55073480409402,"alt":"Standard Power-","position":9,"product_id":10201313345850,"created_at":"2026-02-18T01:43:24-05:00","updated_at":"2026-02-18T01:43:24-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112669536570","width":832,"height":832,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/28_source_1704402231.jpg?v=1771397004","variant_ids":[53038651965754]},{"id":55073480442170,"alt":"International Power Adapter Kit-","position":10,"product_id":10201313345850,"created_at":"2026-02-18T01:43:24-05:00","updated_at":"2026-02-18T01:43:24-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112669569338","width":832,"height":832,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/27_source_1704402231.jpg?v=1771397004","variant_ids":[53038651998522]}],"image":{"id":55073480147258,"alt":"125_main_image_0","position":1,"product_id":10201313345850,"created_at":"2026-02-18T01:43:24-05:00","updated_at":"2026-02-18T01:43:24-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112669274426","width":832,"height":832,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_FGD-WEB600_Left-D__68994.jpg?v=1771397004","variant_ids":[]}}}
