es\/3_source_1701880698.jpg?v=1771395751","variant_ids":[53038608417082]},{"id":55073396293946,"alt":"Solid Door-International Power Supply Kit","position":18,"product_id":10201307316538,"created_at":"2026-02-18T01:22:30-05:00","updated_at":"2026-02-18T01:22:31-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112585453882","width":1000,"height":1135,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/4_source_1701880698.jpg?v=1771395751","variant_ids":[53038608449850]},{"id":55073396326714,"alt":"No Enclosure-Standard Power","position":19,"product_id":10201307316538,"created_at":"2026-02-18T01:22:30-05:00","updated_at":"2026-02-18T01:22:31-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112585486650","width":1000,"height":1003,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/30_source_1704466012.jpg?v=1771395751","variant_ids":[53038608482618]},{"id":55073396359482,"alt":"No Enclosure-International Power Supply Kit","position":20,"product_id":10201307316538,"created_at":"2026-02-18T01:22:30-05:00","updated_at":"2026-02-18T01:22:31-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112585519418","width":1000,"height":1003,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/29_source_1704466012.jpg?v=1771395751","variant_ids":[53038608515386]}],"image":{"id":55073395736890,"alt":"111_main_image_0","position":1,"product_id":10201307316538,"created_at":"2026-02-18T01:22:30-05:00","updated_at":"2026-02-18T01:22:31-05:00","admin_graphql_api_id":"gid:\/\/shopify\/MediaImage\/45112584896826","width":1000,"height":1003,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0987\/4738\/4122\/files\/PH_SCD-1200-Leftv2__66504.jpg?v=1771395750","variant_ids":[]}}}
